# Environment variables for start-spec-driving

# Database Configuration
DATABASE_URL="libsql://your-db-name.turso.io"  # Replace with your Turso database URL
DATABASE_AUTH_TOKEN="your-auth-token"          # Replace with your Turso authentication token

# CORS Configuration
CORS_ORIGIN="http://localhost:3001"            # Frontend origin for CORS

# Node Environment
NODE_ENV="development"                         # development, production, or test

# Seeding Configuration (optional)
SEED_COUNTS="20"                               # Number of seed records to create (default: 20)
ALLOW_SEED="false"                             # Enable seeding (default: false)