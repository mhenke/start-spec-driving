{
  "name": "start-spec-driving",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/node": "^22.13.14",
      "@trpc/server": "^11.7.2",
      "@trpc/client": "^11.7.2",
      "better-auth": "^1.4.18",
      "alchemy": "^0.82.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:native": "bun run --filter native dev",
    "dev:web": "bun run --filter web dev",
    "db:push": "bun run --filter @start-spec-driving/db db:push",
    "db:studio": "bun run --filter @start-spec-driving/db db:studio",
    "db:generate": "bun run --filter @start-spec-driving/db db:generate",
    "db:migrate": "bun run --filter @start-spec-driving/db db:migrate",
    "deploy": "bun run --filter @start-spec-driving/infra deploy",
    "destroy": "bun run --filter @start-spec-driving/infra destroy"
  },
  "dependencies": {
    "@start-spec-driving/env": "workspace:*",
    "alchemy": "^0.83.3",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@start-spec-driving/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.0"
}
