{
  "name": "start-spec-driving",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^3.24.1",
      "typescript": "^5",
      "@types/node": "^22.13.14",
      "@trpc/server": "^11.7.2",
      "@trpc/client": "^11.7.2"
    }
  },
  "resolutions": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:native": "bun run --filter native dev",
    "dev:web": "bun run --filter web dev",
    "db:push": "bun run --filter @start-spec-driving/db db:push",
    "db:studio": "bun run --filter @start-spec-driving/db db:studio",
    "db:generate": "bun run --filter @start-spec-driving/db db:generate",
    "db:migrate": "bun run --filter @start-spec-driving/db db:migrate",
