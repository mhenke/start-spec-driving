  },
  "dependencies": {
    "@start-spec-driving/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@start-spec-driving/config": "workspace:*",
    "@types/node": "catalog:",
    "faker-mcp-server": "https://github.com/funsjanssen/faker-mcp.git",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.0"
